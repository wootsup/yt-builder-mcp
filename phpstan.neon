# Joomla runtime symbols (Joomla\CMS\Factory, Joomla\Database\DatabaseInterface,
# Joomla\CMS\Plugin\CMSPlugin, the WootsUp\Plugin\System\Ytbmcp\Extension class,
# com_ytbmcp Extension classes, `_JEXEC` constant, …) are provided at runtime
# by the Joomla CMS, not by composer. Until a `joomla-stubs` dev-dependency
# lands (deferred — adds ~30 MB to the dev install for what is currently a
# 27-file platform-joomla surface), the Joomla-specific source paths emit
# "unknown class" / "function not found" errors on a level-8 scan.
#
# The `ignoreErrors` block below scopes those suppressions tightly to the
# two Joomla code paths (src/modules/platform-joomla/ and src/packaging/joomla/)
# so the WP-side stays under full level-8 scrutiny.
parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - src/modules/*/vendor/*
        # Joomla packaging tree — Extension classes extend Joomla CMS base
        # classes (CMSPlugin, BaseController, MVCComponent, InstallerScript,
        # HtmlView). These cannot be ignored via ignoreErrors — PHPStan
        # treats "extends unknown class" as structural and requires
        # excludePaths. The build/CI gate covers them through PHPUnit
        # instead (see tests/php/unit/Platform/Joomla/Pin/).
        - src/packaging/joomla/*
        # AbstractApiController extends Joomla\CMS\MVC\Controller\BaseController
        # — same "extends unknown class" pattern that requires excludePaths.
        - src/modules/platform-joomla/src/Rest/AbstractApiController.php
        - src/modules/platform-joomla/src/Rest/Controllers/*
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    universalObjectCratesClasses:
        # YOOtheme service-container is treated as a Pimple-style dictionary;
        # we resolve services via $container[FQCN::class] which PHPStan can't
        # type-check until we ship YT stubs (Wave 3 task).
        - ArrayAccess
    ignoreErrors:
        # YOOtheme runtime symbols — provided by the YOOtheme Pro theme at
        # runtime, not via composer. Stubbing them properly is a Wave 3
        # follow-up; until then, suppress the "unknown class" complaints
        # for the small surface we touch (Path::setAlias, app()).
        -
            message: '#Call to static method setAlias\(\) on an unknown class YOOtheme\\Path\.#'
            path: src/bootstrap.php
        # Module bootstraps register rest_api_init / admin_menu side-effects
        # at module-load time and resolve the YOOtheme DI container lazily
        # via \YOOtheme\app() inside their hook closures. This works around
        # YOOtheme's ExtendLoader requiring a real service id for extend()
        # (arbitrary string keys silently no-op). The app() function is
        # provided by YOOtheme at runtime; stubs land in Wave 3.
        -
            message: '#Function YOOtheme\\app not found\.#'
            paths:
                - src/modules/rest-bridge/bootstrap.php
                - src/modules/builder-pages/bootstrap.php
                - src/modules/builder-elements/bootstrap.php
                - src/modules/builder-inspection/bootstrap.php
                - src/modules/builder-source-binding/bootstrap.php
                - src/modules/platform-wordpress/bootstrap.php
        # wpdb::prepare() requires literal-string SQL, but we interpolate
        # {$wpdb->options} (the table name) into the SQL string. The table
        # name is sourced from WordPress core — not user input — so the
        # interpolation is safe; phpstan-wordpress can't track this.
        # Documented WP-Core pattern: https://developer.wordpress.org/reference/classes/wpdb/prepare/
        -
            message: '#Parameter \#1 \$query of method wpdb::prepare\(\) expects literal-string#'
            paths:
                - src/yt-builder-mcp.php
                - src/uninstall.php
        # wpdb::prepare() returns string|null (null on prepare-failure).
        # Inside deactivation/uninstall paths we accept null-passthrough —
        # query() on a null SQL string is a no-op that wpdb silently ignores.
        # Adding explicit null-guards here adds noise without changing
        # observable behaviour on a fresh deactivate.
        -
            message: '#Parameter \#1 \$query of method wpdb::query\(\) expects string, string\|null given\.#'
            paths:
                - src/yt-builder-mcp.php
                - src/uninstall.php
        # --- Joomla runtime symbols (no composer dep yet) ------------------
        # Joomla\CMS\* / Joomla\Database\* / Joomla\Component\* / etc. are
        # loaded by the Joomla CMS autoloader at runtime, not by composer.
        # Until a `joomla-projects/joomla-stubs` dev-dep lands (deferred —
        # ~30 MB of stubs for what is currently a 27-file platform-joomla
        # surface), the Joomla-specific source paths emit "unknown class"
        # / "function not found" / "invalid type" errors on a level-8 scan.
        # The patterns below suppress those within the two Joomla code paths
        # (modules/platform-joomla/ + packaging/joomla/) ONLY — the WP-side
        # stays under full level-8 scrutiny.
        -
            message: '#unknown class Joomla\\#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#invalid (return )?type Joomla\\#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#(Class|Function) Joomla\\#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        # `throw new Joomla\...\NotAllowed()` in the admin capability gate —
        # PHPStan phrases an unknown instantiated class differently from the
        # "unknown class" / "Class Joomla\..." wordings above.
        -
            message: '#Instantiated class Joomla\\.* not found\.#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#Cannot call method [A-Za-z_]+\(\) on class-string\|object\.#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#Call to an undefined method object::#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#Access to an undefined property WootsUp\\BuilderMcp\\Platform\\Joomla\\#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        # YOOtheme\app() also fires from the Joomla writer (same reason as
        # the WP module bootstraps — YT-DI is runtime-only).
        -
            message: '#Function YOOtheme\\app not found\.#'
            paths:
                - src/modules/platform-joomla/*
        # The plg_system_ytbmcp Extension lives under WootsUp\Plugin\* and
        # is loaded by Joomla's extension autoloader (not the composer PSR-4
        # map — matches the Joomla packaging convention). com_ytbmcp Controller /
        # View / Extension classes follow the same pattern under WootsUp\Component\*.
        -
            message: '#Class (WootsUp\\Plugin\\|WootsUp\\Component\\|Pkg_Ytbmcp).*#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        # Joomla's manifest installer scripts (script.php for plg_system /
        # com_ytbmcp / pkg_ytbmcp) ship without type-declarations on the
        # `$type` / `$parent` parameters by manifest convention — they
        # receive Joomla\CMS\Installer\InstallerAdapter / string at runtime.
        -
            message: '#has parameter \$(parent|type) with no type specified\.#'
            paths:
                - src/packaging/joomla/*
        -
            message: '#has parameter \$headers with no value type specified in iterable type array\.#'
            paths:
                - src/modules/platform-joomla/*
                - src/packaging/joomla/*
        -
            message: '#calls parent::preflight\(\) but [A-Za-z_]+ does not extend any class\.#'
            paths:
                - src/packaging/joomla/*
        # Iterable-type-no-value-specified errors throughout the Joomla
        # module — the cross-platform State/Storage/Pages adapters all
        # operate on heterogeneous layout-state arrays where pinning the
        # value-type would force a deep refactor of the cross-platform
        # interfaces. Defer until the YT-stub work in Wave 5.
        -
            message: '#has parameter \$state with no value type specified in iterable type array\.#'
            paths:
                - src/modules/platform-joomla/*
        # YtBootstrapper proves `function_exists(YOOtheme\\app)` at runtime,
        # but PHPStan can't see the runtime registration that the Joomla-side
        # require() triggers. The "Negated boolean expression is always true"
        # / "Unreachable statement" findings on that block are false-positives
        # against the runtime contract — the bootstrap is the only place that
        # can determine YT-availability.
        -
            message: '#(Negated boolean expression is always true|Unreachable statement - code above always terminates)\.#'
            paths:
                - src/modules/platform-joomla/src/Util/YtBootstrapper.php
