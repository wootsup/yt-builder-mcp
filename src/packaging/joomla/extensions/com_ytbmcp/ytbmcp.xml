<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_ytbmcp</name>
    <author>WootsUp</author>
    <creationDate>2026-05-24</creationDate>
    <copyright>(C) 2026 getimo productions</copyright>
    <license>GPL-2.0-or-later</license>
    <authorEmail>hello@wootsup.com</authorEmail>
    <authorUrl>https://wootsup.com</authorUrl>
    <version>1.1.0</version>
    <description>COM_YTBMCP_XML_DESCRIPTION</description>

    <namespace path="src">WootsUp\Component\Ytbmcp</namespace>

    <!-- Frontend: we ship NO frontend (yt-builder-mcp is admin-only).
         An empty <site> element keeps the manifest valid. -->
    <files />

    <!-- Backend administrator section -->
    <administration>
        <files folder="administrator">
            <!-- Component ACL rule set. Joomla auto-discovers
                 administrator/access.xml, but we list it explicitly so the
                 installer's file manifest copies it on a folder-scoped
                 (method="upgrade") install + surfaces the component in
                 Global Config → Permissions. -->
            <filename>access.xml</filename>
            <!-- Component options/config schema. Joomla's com_config reads
                 administrator/config.xml to render the "Options" toolbar
                 button (+ the Permissions tab). Listed explicitly so the
                 file manifest copies it on a folder-scoped upgrade. W9-T7
                 (#8): yt-builder-mcp has no persistent component-level
                 settings (Bearer keys + uninstall-behaviour live in the DB
                 / system-plugin params), so the schema is intentionally
                 minimal — it exists to surface the Options + Permissions
                 screen at component level per Joomla convention. -->
            <filename>config.xml</filename>
            <folder>language</folder>
            <folder>services</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
        <!-- W9-T7 (#9): branded admin-menu + component icon. The generic
             Joomla cog (img="class:component") is replaced by the WootsUp
             mark shipped under media/com_ytbmcp/images/. `img` is a
             webroot-relative media path (Joomla renders <img src> when the
             value is not a "class:" token). The <icon> element drives the
             component's tile in the admin Components view. -->
        <menu link="option=com_ytbmcp" img="com_ytbmcp/images/icon-ytbmcp.svg">COM_YTBMCP_MENU</menu>
        <icon>com_ytbmcp/images/icon-ytbmcp.svg</icon>
    </administration>

    <!-- Media: installs the package's `media/` folder contents into the
         site's `media/com_ytbmcp/` directory. Ships the Claude-Desktop DXT
         one-click bundle (`yt-builder-mcp.dxt`, injected fresh at build-time —
         never git-tracked). The reveal box serves it via
         `Uri::root() . 'media/com_ytbmcp/yt-builder-mcp.dxt'`. The runtime
         `.encryption_key` (auto-generated by JoomlaEncryptionKeyResolver into
         the same dir) is unaffected — install ships the .dxt, the resolver
         adds its key-file lazily on first key-issue. -->
    <media destination="com_ytbmcp" folder="media">
        <filename>yt-builder-mcp.dxt</filename>
        <!-- W9-T7 (#9): branded menu/component icon. Shipped from the
             git-tracked media/images/ folder (the DXT above is injected at
             build-time into the same media/ stage; the two coexist). -->
        <folder>images</folder>
        <!-- W11 (2026-05-24): the admin dashboard no longer ships a component
             stylesheet. The UI was redesigned to render as a native Joomla
             component (native toolbar + Bootstrap/uitab/Atum components), so
             it carries NO custom colour CSS and follows the Atum admin theme
             (light + dark) for free. The former media/css/admin.css and its
             WebAssetManager registration were removed. -->
    </media>

    <!-- Web Services API section: routes registered by plg_system_ytbmcp
         dispatch into these controllers (`component => com_ytbmcp`). -->
    <api>
        <files folder="api">
            <folder>src</folder>
        </files>
    </api>

    <languages folder="administrator/language">
        <language tag="en-GB">en-GB/com_ytbmcp.ini</language>
        <language tag="en-GB">en-GB/com_ytbmcp.sys.ini</language>
    </languages>
</extension>
